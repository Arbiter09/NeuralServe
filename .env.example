# ─── Model Configuration ────────────────────────────────────────────────────
# Path to base model weights (HuggingFace hub ID or local path)
MODEL_PATH=meta-llama/Meta-Llama-3.1-8B

# Path to LoRA adapter weights directory
ADAPTER_PATH=./outputs/lora-llama3-8b/final_adapter

# ─── Redis Configuration ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── OpenTelemetry Configuration ─────────────────────────────────────────────
# OTLP gRPC endpoint (leave empty to use console exporter for local dev)
OTLP_ENDPOINT=

# ─── WandB Configuration ──────────────────────────────────────────────────────
WANDB_API_KEY=
WANDB_PROJECT=neuralserve
WANDB_ENTITY=

# ─── HuggingFace Configuration ───────────────────────────────────────────────
HF_TOKEN=
HF_HOME=~/.cache/huggingface

# ─── Server Configuration ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=info

# ─── Batch Engine Configuration ──────────────────────────────────────────────
MAX_BATCH_SIZE=8
MAX_WAIT_MS=50

# ─── Cache Configuration ─────────────────────────────────────────────────────
CACHE_TTL_SECONDS=3600

# ─── AWS Configuration (for EC2 deployment) ──────────────────────────────────
AWS_REGION=us-east-1
AWS_INSTANCE_TYPE=g4dn.xlarge

# ─── Grafana Configuration ───────────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=admin
